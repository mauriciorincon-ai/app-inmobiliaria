# Variables de entorno de la app — copia a .env.local (gitignored) y llena lo que uses.
# Los valores reales JAMÁS se commitean; en Vercel van como env vars del proyecto.

# Sentry (opcional — sin DSN el cliente queda inerte, cero ruido en CI/local):
# NEXT_PUBLIC_SENTRY_DSN=

# Nombre de la app para logs/telemetría (opcional):
# NEXT_PUBLIC_APP_NAME=

# El proveedor LLM y sus keys se añaden en el sprint que active IA (ver su ADR).
